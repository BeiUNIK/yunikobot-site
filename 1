<!DOCTYPE html>
<html>
<head>
    <title>YunikoBot</title>
    <style>
        body { font-family: Arial; margin: 0; padding: 0; }
        .hero { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 100px 20px; text-align: center; }
        .hero h1 { font-size: 3rem; margin-bottom: 20px; }
        .btn { background: white; color: #667eea; padding: 15px 40px; border-radius: 50px; text-decoration: none; font-weight: bold; display: inline-block; margin: 10px; border: none; cursor: pointer; font-size: 1rem; }
        .pricing { padding: 80px 20px; background: #f8f9fa; text-align: center; }
        .card { background: white; padding: 40px; border-radius: 15px; display: inline-block; margin: 20px; width: 300px; box-shadow: 0 5px 20px rgba(0,0,0,0.1); }
        .price { font-size: 3rem; color: #667eea; font-weight: bold; }
        ul { list-style: none; padding: 0; text-align: left; }
        li { padding: 10px 0; }
        li:before { content: "✓ "; color: green; }
        #popup { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; }
        #popup.active { display: flex; }
        .popup-content { background: white; padding: 40px; border-radius: 20px; text-align: center; max-width: 400px; }
        input { width: 100%; padding: 15px; margin: 10px 0; border: 2px solid #ddd; border-radius: 10px; font-size: 1rem; }
    </style>
</head>
<body>
    <div class="hero">
        <h1>Create Content 10x Faster</h1>
        <p>AI-powered content creation for creators and businesses</p>
        <button class="btn" onclick="showPopup()">Start Free Trial</button>
    </div>
    
    <div class="pricing">
        <h2>Pricing</h2>
        <div class="card">
            <h3>Starter</h3>
            <div class="price">$27/mo</div>
            <ul>
                <li>10,000 AI words</li>
                <li>5 blog posts</li>
                <li>Email support</li>
            </ul>
            <button class="btn" onclick="showPopup()">Start Free Trial</button>
        </div>
        <div class="card">
            <h3>Pro</h3>
            <div class="price">$97/mo</div>
            <ul>
                <li>Unlimited words</li>
                <li>Unlimited posts</li>
                <li>Priority support</li>
            </ul>
            <button class="btn" onclick="showPopup()">Start Free Trial</button>
        </div>
    </div>
    
    <div id="popup">
        <div class="popup-content">
            <h3>Start Your Free Trial</h3>
            <input type="email" id="email" placeholder="your@email.com">
            <button class="btn" onclick="submitEmail()">Continue</button>
            <p style="font-size: 0.8rem; color: #666;">No credit card required</p>
        </div>
    </div>
    
    <script>
        function showPopup() {
            document.getElementById('popup').classList.add('active');
        }
        function submitEmail() {
            var email = document.getElementById('email').value;
            if(email && email.includes('@')) {
                alert('Thanks! Check your email for next steps.');
                document.getElementById('popup').classList.remove('active');
            } else {
                alert('Please enter a valid email');
            }
        }
        document.getElementById('popup').onclick = function(e) {
            if(e.target === this) this.classList.remove('active');
        }
    </script>
</body>
</html>
